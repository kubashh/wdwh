{
  "name": "wdwh",
  "version": "1.12.20",
  "author": "kubashh",
  "description": "The Bun Frontend Framework.",
  "license": "MIT",
  "repository": "https://github.com/kubashh/wdwh",
  "keywords": [
    "react",
    "framework",
    "wdwh",
    "web",
    "bun",
    "typescript",
    "frontend"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "hooks.js",
    "hooks.d.ts",
    "components.js",
    "components.d.ts",
    "wdwh.js"
  ],
  "scripts": {
    "dev": "clear && bun dev/dev.ts --wdwh-dev",
    "build": "bun dev/scripts.ts --wdwh-dev",
    "pub": "bun dev/scripts.ts --publish",
    "zip": "rm -f template/template.zip && zip -r template/template.zip template/template"
  },
  "bin": {
    "wdwh": "./wdwh.js"
  },
  "dependencies": {
    "bun-plugin-tailwind": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "prettier": {
    "printWidth": 108
  }
}
